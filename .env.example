# =====================================
# Local dev: copy thành .env
# EAS Workflows: set vào expo.dev → Project → Secrets
# =====================================

# Web (Next.js BE) のベース URL
# - Android emulator: http://10.0.2.2:3000
# - 実機テスト: http://<PC の LAN IP>:3000
# - 本番: Railway のデプロイ URL
API_BASE_URL=http://10.0.2.2:3000

# EAS project ID (expo.dev で project 作成後にコピー)
# Local 起動時は不要、EAS build 時のみ必要
EAS_PROJECT_ID=
