# =====================================
# Local dev: copy thành .env
# CI: set vào GitHub Actions Secrets
# =====================================

# Web (Next.js BE) のベース URL
# - Android emulator: http://10.0.2.2:3000 (host の localhost に到達するエイリアス)
# - 実機テスト: http://<PC の LAN IP>:3000
# - 本番: Railway のデプロイ URL
API_BASE_URL=http://10.0.2.2:3000

# EAS Build 用の project ID (expo.dev で project 作成後にコピー)
# Local 起動時は不要、`eas build` 実行時のみ必要
EAS_PROJECT_ID=
